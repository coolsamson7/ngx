{
  "name": "microfrontend",
  "targets": {
    "build": {
      "executor": "@nx/angular:webpack-browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/microfrontend",
        "index": "apps/microfrontend/src/index.html",
        "main": "apps/microfrontend/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/microfrontend/tsconfig.app.json",
        "customWebpackConfig": {
          "path": "apps/microfrontend/webpack.config.ts"
        },
        "assets": ["apps/microfrontend/src/favicon.ico", "apps/microfrontend/src/assets"],
        "styles": ["apps/microfrontend/src/styles.scss"],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": []
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@nx/angular:dev-server",
      "options": {
        "buildTarget": "microfrontend:build",
          "port": 4201,
          "publicHost": "http://localhost:4200"
      }
    }
  }
}