{
  "name": "my-shell",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/my-shell/src",
  "tags": [],
  "targets": {
    "generate-icons": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/my-shell/src/app/icons/generated"],
      "inputs": [
        { "fileset": "{projectRoot}/src/assets/icons/*.svg" }
      ],
      "options": {
        "command": "pnpm exec svg-to-ts-constants",
        "cwd": "apps/my-shell"
      }
    },
    "build": {
      "executor": "@nx/angular:webpack-browser",
      "dependsOn": ["^build"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/my-shell",
        "index": "apps/my-shell/src/index.html",
        "main": "apps/my-shell/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/my-shell/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
           {
            "glob": "**/*",
            "input": "apps/my-shell/src/assets",
            "output": "assets"
          },
          {
            "glob": "**/*",
            "input": "apps/my-shell/public"
          }
        ],
        "styles": [
          "apps/my-shell/src/styles.scss"
        ],
        "customWebpackConfig": {
          "path": "apps/my-shell/webpack.config.js"
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "customWebpackConfig": {
            "path": "apps/my-shell/webpack.prod.config.js"
          }
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        },
        "source": {
          "tsConfig": "apps/my-shell/tsconfig.app.json"
        }
      },
      "defaultConfiguration": "development"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/angular:module-federation-dev-server",
      "options": {
        "port": 4200,
        "poll": 0,
        "liveReload": false,
        "hmr": false

      },
      "configurations": {
        "production": {
          "buildTarget": "my-shell:build:production"
        },
        "development": {
          "buildTarget": "my-shell:build:development"
        },
        "source": {
          "buildTarget": "my-shell:build:source"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "my-shell:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/my-shell/**/*.{ts,tsx,js,jsx}"],
        "eslintConfig": "eslint.config.mjs"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/my-shell/jest.config.ts",
        "tsConfig": "apps/my-shell/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "my-shell:build",
        "spa": true
      }
    },
    "generate-lib-meta": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run generate-lib-meta -- apps/my-shell"
      }
    }
  }
}
