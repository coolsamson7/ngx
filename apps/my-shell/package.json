{
  "name": "@ngx/my-shell",
  "version": "0.0.1",
  "svg-to-ts": {
    "conversionType": "constants",
    "srcFiles": ["src/assets/icons/*.svg"],
    "outputDirectory": "src/app/icons/generated",
    "typeName": "AppIconName",
    "prefix": "appIcon",
    "svgoConfig": {
      "plugins": [{ "name": "preset-default" }]
    }
  },
  "peerDependencies": {
    "@angular/common": "^19.0.0",
    "@angular/core": "^19.0.0",

    "@ngx/common": "workspace:*",
    "@ngx/communication": "workspace:*",
    "@ngx/i18n": "workspace:*",
    "@ngx/portal": "workspace:*",
    "@ngx/security": "workspace:*",
    "@ngx/foundation": "workspace:*",

    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "webpack": "5.105.0",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2"
  }
}