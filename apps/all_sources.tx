

===== FILE: ./microfrontend/module-federation.config.js =====

const { ModuleFederationConfig } = require('@nx/module-federation');

/**
 * @type {import('@nx/module-federation').ModuleFederationConfig}
 */
const config = {
  name: 'microfrontend',
  exposes: {
    './Module': './src/app/app.module.ts',
  },
};

module.exports = config;

===== FILE: ./microfrontend/project.json =====

{
  "name": "microfrontend",
  "root": "apps/microfrontend",
  "sourceRoot": "apps/microfrontend/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/angular:webpack-browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/microfrontend",
        "index": "apps/microfrontend/src/index.html",
        "main": "apps/microfrontend/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/microfrontend/tsconfig.app.json",
        "customWebpackConfig": {
          "path": "apps/microfrontend/webpack.config.js"
        }
      },
      "configurations": {
        "production": {
          "optimization": true,
          "sourceMap": false,
          "namedChunks": false,
          "aot": true,
          "extractLicenses": true,
          "vendorChunk": false
        },
        "development": {
          "optimization": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "development"
    },
    "serve": {
      "executor": "@nx/angular:webpack-dev-server",
      "options": {
        "buildTarget": "microfrontend:build",
        "port": 4201
      },
      "configurations": {
        "production": {
          "buildTarget": "microfrontend:build:production"
        },
        "development": {
          "buildTarget": "microfrontend:build:development"
        }
      },
      "defaultConfiguration": "development"
    }
  }
}

===== FILE: ./microfrontend/src/index.ts =====

import { NgModule, Component } from '@angular/core';
import { RouterModule, Routes } from '@angular/router';
import { CommonModule } from '@angular/common';

@Component({
  selector: 'app-portal',
  template: `<h2>Portal Module</h2>`
})
export class PortalComponent {}

const routes: Routes = [{ path: '', component: PortalComponent }];

@NgModule({
  imports: [CommonModule, RouterModule.forChild(routes)],
  declarations: [PortalComponent]
})
export class PortalModule {}

