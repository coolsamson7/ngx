{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": []
  },
  "files": [
    "src/main.ts"
  ],
  "exclude": ["**/*.spec.ts", "jest.config.ts", "src/test-setup.ts"],
  "include": ["src/**/*.ts"]
}

