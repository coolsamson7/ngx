{
  "name": "my-nx-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "generate-lib-meta": "tsc tools/scripts/generate-lib-meta.ts --outDir dist/tools && node dist/tools/generate-lib-meta.js",
    "docs": "npx compodoc -p tsconfig.compodoc.json",
    "start:shell": "nx serve shell",
    "start:microfrontend": "nx run microfrontend:serve:standalone",
    "build:shell": "nx build shell",
    "build:portal": "nx build portal",
    "build": "nx run-many --target=build --all --parallel=false",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all"
  },
  "workspaces": [
    "tools/*"
  ],
  "dependencies": {
    "@angular/animations": "19.2.0",
    "@angular/cdk": "^19.2.0",
    "@angular/common": "19.2.0",
    "@angular/compiler": "19.2.0",
    "@angular/core": "19.2.0",
    "@angular/forms": "19.2.0",
    "@angular/material": "^19.2.0",
    "@angular/platform-browser": "19.2.0",
    "@angular/platform-browser-dynamic": "19.2.0",
    "@angular/router": "19.2.0",
    "@ngx/common": "workspace:*",
    "@ngx/i18n": "workspace:*",
    "@ngx/portal": "workspace:*",
    "@ngx/security": "workspace:*",
    "@ngx/validation": "workspace:*",
    "@nx/angular": "21.6.10",
    "reflect-metadata": "^0.2.2",
    "rxjs": "~7.8.0",
    "source-map-js": "^1.2.1",
    "tslib": "^2.8.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "19.2.0",
    "@angular-devkit/core": "19.2.0",
    "@angular-devkit/schematics": "19.2.0",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular/build": "19.2.0",
    "@angular/compiler-cli": "19.2.0",
    "@compodoc/compodoc": "^1.2.1",
    "@module-federation/enhanced": "^0.18.0",
    "@nx/devkit": "21.6.10",
    "@nx/eslint": "^21.6.10",
    "@nx/eslint-plugin": "^21.6.10",
    "@nx/jest": "21.6.10",
    "@nx/js": "21.6.10",
    "@nx/module-federation": "21.6.10",
    "@nx/playwright": "21.6.10",
    "@nx/web": "21.6.10",
    "@nx/webpack": "21.6.10",
    "@nx/workspace": "21.6.10",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "19.2.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.21",
    "@swc/helpers": "~0.5.11",
    "@types/jest": "^29.5.12",
    "@types/node": "25.5.0",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^19.2.0",
    "eslint-plugin-playwright": "^1.6.2",
    "find-in-files": "^0.5.0",
    "find-nearest-package-json": "^2.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "~14.4.0",
    "jest-util": "^29.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "ng-packagr": "^19.2.0",
    "nx": "21.6.10",
