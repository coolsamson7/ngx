{
  "root": "libs/communication",
  "sourceRoot": "libs/communication/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "options": { "tsConfig": "libs/ui/tsconfig.lib.json" },
      "dependsOn": ["xgenerate-lib-meta"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/communication/**/*.{ts,tsx,js,jsx}"],
        "eslintConfig": "eslint.config.mjs"
      }
    },
    "generate-lib-meta": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run generate-lib-meta -- libs/communication"
      }
    }
  }
}