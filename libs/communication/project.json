{
  "root": "libs/communication",
  "sourceRoot": "libs/communication/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "options": { "tsConfig": "libs/ui/tsconfig.lib.json" },
      "dependsOn": ["generate-lib-meta"]
    },
    "generate-lib-meta": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node tools/scripts/generate-lib-meta.ts libs/communication"
      }
    }
  }
}