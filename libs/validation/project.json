{
  "root": "libs/validation",
  "sourceRoot": "libs/validation/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "options": { "tsConfig": "libs/validation/tsconfig.lib.json" },
      "dependsOn": ["xgenerate-lib-meta"]
    },
    "generate-lib-meta": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run generate-lib-meta -- libs/validation"
      }
    }
  }
}