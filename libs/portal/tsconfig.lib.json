{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "target": "es2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": [],
    "declaration": true,
    "composite": true,
    "paths": {
      "@ngx/common": ["../../dist/libs/common"],
      "@ngx/i18n": ["../../dist/libs/i18n"],
      "@ngx/security": ["../../dist/libs/security"]
    }
  },
  "exclude": ["**/*.spec.ts", "jest.config.ts", "src/test-setup.ts"],
  "include": ["**/*.ts"],
  "references": [
    { "path": "../common" },
    { "path": "../security" },
    { "path": "../i18n" }
  ]
}