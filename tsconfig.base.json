{
  "compileOnSave": false,
  "compilerOptions": {
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
    },
    "target": "es2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}
