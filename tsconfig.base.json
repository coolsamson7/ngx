{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ngx/common": ["libs/common/src/index.ts"],
      "@ngx/portal": ["libs/portal/src/index.ts"],
      "microfrontend/Routes": [
        "apps/microfrontend/src/app/remote-entry/entry.routes.ts"
      ]
    },
    "target": "es2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}
