{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ngx/common": ["libs/common/src/index.ts"],
      "@ngx/component": ["libs/component/src/index.ts"],
      "@ngx/communication": ["libs/communication/src/index.ts"],
      "@ngx/i18n": ["libs/i18n/src/index.ts"],
      "@ngx/portal": ["libs/portal/src/index.ts"],
      "@ngx/security": ["libs/security/src/index.ts"],
      "@ngx/ui": ["libs/ui/src/index.ts"],
      "@ngx/validation": ["libs/validation/src/index.ts"],
      "@ngx/view": ["libs/view/src/index.ts"]
    },
    "target": "es2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}
